ATTRS = {}
_PAIR = {}


def _pair_for(colnum):
    if colnum not in _PAIR:
        idx = len(_PAIR) + 1
        try:
            curses.init_pair(idx, colnum, -1)
        except curses.error:
            return curses.A_NORMAL
        _PAIR[colnum] = curses.color_pair(idx)
    return _PAIR[colnum]


def init_colors():
    ATTRS.clear()
    _PAIR.clear()
    if not curses.has_colors():
        for letter in list(BASE_COLORS) + list(EXT_COLORS):
            ATTRS[letter] = curses.A_NORMAL
            ATTRS[letter.upper()] = curses.A_BOLD
        ATTRS["E"] = curses.A_BOLD
        return
    curses.start_color()
    try:
        curses.use_default_colors()
    except curses.error:
        pass
    many = curses.COLORS >= 256
    for letter, num in BASE_COLORS.items():
        ATTRS[letter] = _pair_for(num)
        ATTRS[letter.upper()] = _pair_for(num) | curses.A_BOLD
    for letter, (num, fb) in EXT_COLORS.items():
        if many:
            ATTRS[letter] = _pair_for(num)
        else:
            ATTRS[letter] = ATTRS[fb.lower()] | (curses.A_BOLD if fb.isupper() else 0)
    ATTRS["E"] = ATTRS["W"]  # sasquatch eyes; re-pointed red at night


def set_night_palette(is_night):
    if "R" in ATTRS and "W" in ATTRS:
        ATTRS["E"] = ATTRS["R"] if is_night else ATTRS["W"]


