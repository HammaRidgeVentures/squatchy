def tree_frames(art):
    """Two frames: still, and canopy nudged a column (wind sway)."""
    lines = art.split("\n")
    trunk_start = next((i for i, l in enumerate(lines) if "|" in l and "/" not in l), len(lines))
    swayed = []
    for i, l in enumerate(lines):
        swayed.append((" " + l) if i < trunk_start else l)
    return [art, "\n".join(swayed)]


def make_ridge(w, mh, snowline):
    cols = []
    level = random.randint(1, max(2, mh // 2))
    while len(cols) < w:
        peak = random.randint(3, mh)
        for yy in range(level, peak + 1):
            cols.append(("/", yy))
        valley = random.randint(1, max(1, mh // 2))
        for yy in range(peak - 1, valley - 1, -1):
            cols.append(("\\", yy))
        level = valley
    grid = [[" "] * w for _ in range(mh)]
    mask = [[" "] * w for _ in range(mh)]
    for x in range(w):
        ch, yy = cols[x]
        row = mh - yy
        if 0 <= row < mh:
            grid[row][x] = ch
            mask[row][x] = "W" if yy >= snowline else " "
    return "\n".join("".join(r) for r in grid), "\n".join("".join(r) for r in mask)


def make_water_frames(w):
    """Four phase-shifted frames of the same surface = drifting shimmer."""
    base = []
    for density in (0.85, 0.28, 0.14):
        base.append("".join("~" if random.random() < density else " " for _ in range(w)))
    frames, masks = [], []
    for k in range(4):
        rows, mrows = [], []
        for i, row in enumerate(base):
            s = k * (i + 1) * 2 % w
            shifted = row[s:] + row[:s]
            rows.append(shifted)
            letter = "N" if i == 0 else "n"
            mrows.append("".join(letter if ch == "~" else " " for ch in shifted))
        frames.append("\n".join(rows))
        masks.append("\n".join(mrows))
    return frames, masks


def make_grass(w):
    art, mask = [], []
    for density in (0.28, 0.45):
        row, mrow = [], []
        for _ in range(w):
            roll = random.random()
            if roll < density * 0.06:
                row.append("Y"); mrow.append("F")          # tiny fern
            elif roll < density:
                ch = random.choice(".,'\"`,")
                row.append(ch); mrow.append(random.choice("gfF"))
            else:
                row.append(" "); mrow.append(" ")
        art.append("".join(row))
        mask.append("".join(mrow))
    return "\n".join(art), "\n".join(mask)


# --------------------------------------------------------------------------
# engine
# --------------------------------------------------------------------------

class Entity:
    def __init__(self, frames, x, y, z, *, masks=None, color="w", dx=0.0, dy=0.0,
                 anim_every=6, die_offscreen=False, floor=None, expires=None,
                 update_fn=None, kind="misc", data=None):
        self.x, self.y, self.z = float(x), float(y), z
        self.dx, self.dy = dx, dy
        self.color = color
        self.anim_every = anim_every
        self.die_offscreen = die_offscreen
        self.floor = floor
        self.expires = expires
        self.update_fn = update_fn
        self.kind = kind
        self.data = data or {}
        self.frame_idx = 0
        self._anim_tick = 0
        self.dead = False
        self.hidden = False
        self.clip_y = None      # rows below this screen row are not drawn
        self.set_art(frames, masks)

    def set_art(self, frames, masks=None):
        self.frames = [frame_lines(f) for f in frames]
        self.masks = [frame_lines(m) for m in masks] if masks else None
        self.width = max((len(l) for f in self.frames for l in f), default=1)
        self.height = max((len(f) for f in self.frames), default=1)
        self.frame_idx = min(self.frame_idx, len(self.frames) - 1)
        self.runs = [self._compile(i) for i in range(len(self.frames))]

    def _compile(self, i):
        rows = []
        lines = self.frames[i]
        mlines = self.masks[i] if self.masks else None
        for r, line in enumerate(lines):
            mline = mlines[r] if mlines and r < len(mlines) else ""
            runs = []
            col = 0
            n = len(line)
            while col < n:
                if line[col] == " ":
                    col += 1
                    continue
                letter = mline[col] if col < len(mline) and mline[col] != " " else self.color
                start = col
                while (col < n and line[col] != " "
                       and (mline[col] if col < len(mline) and mline[col] != " " else self.color) == letter):
                    col += 1
                # '?' is an opaque space: blanks whatever is behind the sprite
                runs.append((start, line[start:col].replace("?", " "), letter))
            rows.append(runs)
        return rows

    def default_move(self):
        self.x += self.dx
        self.y += self.dy
        self._anim_tick += 1
        if self._anim_tick >= self.anim_every and len(self.frames) > 1:
            self._anim_tick = 0
            self.frame_idx = (self.frame_idx + 1) % len(self.frames)

    def update(self, scene, now):
        if self.update_fn:
            self.update_fn(self, scene, now)
        else:
            self.default_move()
        if self.expires is not None and now >= self.expires:
            self.dead = True
        if self.floor is not None and self.y + self.height - 1 >= self.floor:
            self.dead = True
        if self.die_offscreen:
            if self.dx > 0 and self.x > scene.w:
                self.dead = True
            elif self.dx < 0 and self.x + self.width < 0:
                self.dead = True
            if self.dy > 0 and self.y > scene.h:
                self.dead = True

    def draw(self, scr, h, w):
        if self.hidden:
            return
        xi, yi = int(self.x), int(self.y)
        yi += self.height - len(self.frames[self.frame_idx])   # bottom-align
        for r, runs in enumerate(self.runs[self.frame_idx]):
            sy = yi + r
            if sy < 0 or sy >= h:
                continue
            if self.clip_y is not None and sy > self.clip_y:
                break
            for col, text, letter in runs:
                sx = xi + col
                if sx + len(text) <= 0 or sx >= w:
                    continue
                if sx < 0:
                    text = text[-sx:]
                    sx = 0
                if sx + len(text) > w:
                    text = text[: w - sx]
                try:
                    scr.addstr(sy, sx, text, ATTRS.get(letter, curses.A_NORMAL))
                except curses.error:
                    pass


