#!/usr/bin/env python3
"""Squatchy — a Pacific Northwest scene in ASCII art, in the spirit of asciiquarium.

Keys:
  q       quit
  p/space pause
  r       redraw / rebuild the scene
  w       toggle rain
  n       skip to the next time of day
  s       (shhh) summon a sasquatch
  o       (shhh) summon an orca

Requires only Python 3 and a curses-capable terminal.
"""

import curses
import math
import random
import time

FRAME_MS = 65          # ~15 fps
HINT_SECONDS = 6

# day/night cycle (seconds)
DAY_LEN, DUSK_LEN, NIGHT_LEN, DAWN_LEN = 150, 25, 150, 25
CYCLE_LEN = DAY_LEN + DUSK_LEN + NIGHT_LEN + DAWN_LEN

# --------------------------------------------------------------------------
# helpers
# --------------------------------------------------------------------------

MIRROR_MAP = str.maketrans(r"/\()<>[]{}`'", r"\/)(><][}{'`")


def mirror(art):
    lines = art.split("\n")
    w = max(len(l) for l in lines) if lines else 0
    return "\n".join(l.ljust(w)[::-1].translate(MIRROR_MAP) for l in lines)


def frame_lines(art):
    lines = art.split("\n")
    while lines and not lines[0].strip():
        lines.pop(0)
    while lines and not lines[-1].strip():
        lines.pop()
    w = max((len(l) for l in lines), default=0)
    return [l.ljust(w) for l in lines]


def mask_from(art, mapping):
    return "\n".join(
        "".join(mapping.get(ch, " ") for ch in line) for line in art.split("\n")
    )


def smooth(t):
    """ease-in-out 0..1"""
    t = max(0.0, min(1.0, t))
    return t * t * (3 - 2 * t)


